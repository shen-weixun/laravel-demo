{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "config": {
      "buildCommand": "composer install --optimize-autoloader && npm ci && npm run build",
      "startCommand": "php artisan serve --host=0.0.0.0 --port=${PORT:-8000}",
      "nixpacks": {
        "providers": ["php", "nodejs"],
        "node": {
          "version": "20"
        }
      }
    }
  }
}
