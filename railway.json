{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "config": {
      "buildCommand": "composer update --no-scripts --no-dev && npm ci && npm run build",
      "startCommand": "vendor/bin/heroku-php-apache2 public/",
      "nixpacks": {
        "providers": ["php", "nodejs"],
        "node": {
          "version": "20"
        }
      }
    }
  }
}
