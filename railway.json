{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "config": {
      "buildCommand": "composer install --no-dev && npm install && npm run build",
      "startCommand": "vendor/bin/heroku-php-apache2 public/",
      "nixpacks": {
        "providers": ["php", "nodejs"]
      },
      "php": {
        "version": "8.2"
      }
    }
  }
}
